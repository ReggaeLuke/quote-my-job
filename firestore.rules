rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow public quote submissions
    match /quotes/{quoteId} {
      // Any authenticated user can read quotes
      allow read: if request.auth != null;

      allow create: if request.resource.data.keys().hasOnly(['name', 'mobile', 'category', 'jobDescription', 'status', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.mobile is string
        && request.resource.data.mobile.size() > 0
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        && request.resource.data.jobDescription is string
        && request.resource.data.jobDescription.size() >= 10
        && request.resource.data.status == 'Pending';

      // Authenticated users can update only the status field
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['Pending', 'Contacted', 'Cancelled', 'Closed'];
    }
  }
}